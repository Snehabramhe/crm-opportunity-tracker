# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- Database ----
# MongoDB Atlas connection string (or local mongodb://127.0.0.1:27017/crm)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/crm?retryWrites=true&w=majority

# ---- Auth ----
# Use a long, random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=2h
# Cookie lifetime in milliseconds (2 hours)
COOKIE_MAX_AGE=7200000

# ---- CORS ----
# Exact origin of the deployed frontend (no trailing slash). Comma-separate for multiple.
CLIENT_ORIGIN=http://localhost:5173
